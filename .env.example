AUTH_ENABLED=true

# Заполните перед запуском
DASHBOARD_USER=your_user
DASHBOARD_PASS=your_password

# Путь к лог-файлу Xray
ERROR_LOG_PATH=./error.log

# Первый запуск: true = начать с конца файла (не импортировать старый хвост), false = прочитать весь файл с начала
ERROR_LOG_SKIP_HISTORY=true

# Подстроки в строке лога (через запятую, регистр не важен). Строка попадаёт в дашборд, если содержит любую из них.
ERROR_LOG_LINE_MARKERS=failed,invalid connection,server name mismatch

# Обогащение IP-профиля (owner/asn/location)
GEO_LOOKUP_ENABLED=true
GEO_LOOKUP_DAILY_LIMIT=1699
