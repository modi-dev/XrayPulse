AUTH_ENABLED=true

# Примечание: при загрузке используется override=True — значения из .env перекрывают
# переменные, уже заданные в окружении ОС/терминала/IDE (иначе AUTH_ENABLED из .env мог бы не применяться).

# Заполните перед запуском (форма входа / сессия)
DASHBOARD_USER=your_user
DASHBOARD_PASS=your_password

# Секрет подписи cookie сессии; в проде задайте длинную случайную строку (openssl rand -hex 32)
# Если не задан — при каждом перезапуске приложения сессии сбрасываются
FLASK_SECRET_KEY=

# Защита от брутфорса /login: число неверных попыток с одного IP, затем пауза (секунды)
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300

# За reverse-proxy (nginx и т.п.): true = для лимита попыток брать IP из X-Forwarded-For (первый адрес)
AUTH_TRUST_X_FORWARDED=false

# Путь к лог-файлу Xray
ERROR_LOG_PATH=./error.log

# Первый запуск: true = начать с конца файла (не импортировать старый хвост), false = прочитать весь файл с начала
ERROR_LOG_SKIP_HISTORY=true

# Подстроки в строке лога (через запятую, регистр не важен). Строка попадаёт в дашборд, если содержит любую из них.
ERROR_LOG_LINE_MARKERS=failed,invalid connection,server name mismatch

# Маркеры «шума» (скан TLS, мусор на порту): фильтр «Скрыть шум» в дашборде. PROBE_NOISE_MARKERS — полная замена списка;
# PROBE_NOISE_EXTRA_MARKERS — дополнительные подстроки к встроенному списку (через запятую).
# PROBE_NOISE_EXTRA_MARKERS=bad user agent,custom noise phrase

# Обогащение IP-профиля (owner/asn/location)
GEO_LOOKUP_ENABLED=true
GEO_LOOKUP_DAILY_LIMIT=1699

# Ротация monitor_job.log (метрики и служебные сообщения приложения)
MONITOR_JOB_LOG_PATH=monitor_job.log
MONITOR_JOB_LOG_MAX_BYTES=5242880
MONITOR_JOB_LOG_BACKUP_COUNT=5
